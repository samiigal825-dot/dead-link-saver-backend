# Database Connection URI (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Application Settings
PORT=5000

# Secret phrase to authorize cron checking trigger (?secret=...)
CRON_SECRET=super_secret_cron_passphrase

# Optional Telegram Settings for Notifications (Leave blank to disable)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-100123456789
